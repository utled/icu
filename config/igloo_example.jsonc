{
	# largeSyncPath determines the index scope for initial/full scanning and the continuous largeSyncScan
	"largeSyncPath": string,
	# quickSyncPath determines the scope for the more frequent continious quickSyncScan
	"quickSyncPath": string,
	# largeSyncFrequenzy determines what nth scan runs the large scope (i.e with largeSyncFrequenzy = 5 every 5th sync loop takes full scope while the other 4 runs the quick scope)
	"largeSyncFrequenzy": int,
}
